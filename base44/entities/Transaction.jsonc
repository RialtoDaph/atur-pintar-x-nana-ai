{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "account_id": {
      "type": "string",
      "description": "ID rekening terkait"
    },
    "goal_id": {
      "type": "string",
      "description": "ID of the savings goal (if linked)"
    },
    "debt_id": {
      "type": "string",
      "description": "ID of the debt (if this transaction is a debt payment)"
    },
    "amount": {
      "type": "number",
      "description": "Amount of the transaction"
    },
    "type": {
      "type": "string",
      "enum": [
        "income",
        "expense",
        "savings"
      ],
      "default": "expense"
    },
    "category": {
      "type": "string",
      "description": "Category key (default or custom_<id>)"
    },
    "note": {
      "type": "string",
      "description": "Description or merchant name"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "is_recurring": {
      "type": "boolean",
      "default": false
    },
    "recurring_interval": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "yearly"
      ]
    },
    "recurring_last_generated": {
      "type": "string",
      "format": "date"
    },
    "is_recurring_child": {
      "type": "boolean",
      "default": false
    },
    "recurring_parent_id": {
      "type": "string"
    }
  },
  "required": [
    "amount",
    "type",
    "date"
  ],
  "rls": {
    "enabled": true,
    "filter_field": "created_by",
    "filter_value": "{{user.email}}"
  }
}